<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.haruhi.botServer.mapper.ChatRecordGroupMapper">

    <sql id="base_columns">
        id,card,nickname,message_id,user_id,self_id,content,deleted,time
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyColumn="id" keyProperty="param.id">
     INSERT INTO ${tableName}(card,nickname,message_id,user_id,self_id,content,time)
     values(#{param.card},#{param.nickname},#{param.messageId},#{param.userId},#{param.selfId},#{param.content},#{param.time})
    </insert>

    <select id="selectList" resultType="com.haruhi.botServer.entity.ChatRecordGroup">
        select <include refid="base_columns"></include>
        from ${tableName}
        <where>
            <if test="param.userId != null">
                and user_id = #{param.userId}
            </if>
            <if test="param.userIds != null and param.userIds.size()>0">
                and user_id in
                <foreach collection="param.userIds" open="(" close=")" index="index" item="userId" separator=",">
                    #{userId}
                </foreach>
            </if>
            <if test="param.selfId != null">
                and self_id = #{param.selfId}
            </if>
            <if test='param.startTime != null and param.startTime != ""'>
                and `time` &gt;= #{param.startTime}
            </if>
            <if test='param.endTime != null and param.endTime != ""'>
                and `time` &lt;= #{param.endTime}
            </if>
            <if test='param.content != null and param.content != ""'>
                and content LIKE CONCAT('%',#{param.content},'%')
            </if>
        </where>
        order by `time` ${param.sort}
    </select>

    <select id="chatStats" resultType="com.haruhi.botServer.entity.vo.ChatRecordVo">
        SELECT
            user_id,
            count(1) as total
        FROM ${tableName}
        WHERE self_id = #{selfId}
        group by user_id
        ORDER BY total desc
    </select>
    <select id="selectWordCloudCorpus" resultType="com.haruhi.botServer.entity.ChatRecordGroup">
        select <include refid="base_columns"></include>
        FROM ${tableName}
        <where>
            self_id = #{selfId} and user_id != #{selfId} and `time` &gt;= #{startTime}
            <if test="userIds != null and userIds.size()>0">
                and user_id in
                <foreach collection="userIds" open="(" close=")" index="index" item="userId" separator=",">
                    #{userId}
                </foreach>
            </if>
            <if test="excludeContent != null and excludeContent.size()>0">
                and
                <foreach collection="excludeContent" item="item" separator="AND" open="(" close=")">
                    content NOT LIKE CONCAT('%', #{item}, '%')
                </foreach>
            </if>
        </where>
    </select>

</mapper>